<?xml version="1.0" encoding="utf-8"?>
<!--
  Focused background for list items and row-style clickable areas.
  - focused: orange tint fill + orange left border bar
  - pressed: darker orange tint
  - default: transparent
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused state: semi-transparent orange fill + 4dp left accent bar -->
    <item android:state_focused="true" android:state_enabled="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#1Af97910" />
                    <stroke android:width="2dp" android:color="#CCf97910" />
                    <corners android:radius="4dp" />
                </shape>
            </item>
            <item android:right="9999dp" android:top="4dp" android:bottom="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="#f97910" />
                    <corners android:topRightRadius="2dp" android:bottomRightRadius="2dp" />
                    <size android:width="4dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#33f97910" />
            <corners android:radius="4dp" />
        </shape>
    </item>

    <!-- Default: transparent -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
        </shape>
    </item>

</selector>

